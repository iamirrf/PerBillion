# PerBillion Production Environment
# Copy to .env.production on the server. Replace every change_me value.

DOMAIN=perbillion.com
ACME_EMAIL=admin@perbillion.com

# MongoDB — the prod compose builds the URI from MONGO_PASSWORD automatically.
# Only set MONGODB_URI if you want to use an external database (e.g. Atlas).
MONGO_PASSWORD=change_me_strong_mongo_password
MONGODB_DATABASE=perbillion

# JWT
JWT_SECRET=change_me_256_bit_jwt_secret
JWT_EXPIRY=7d

# Alpha Vantage — get a free key at https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=change_me_alpha_vantage_key

# Application URLs
FRONTEND_URL=https://perbillion.com
API_URL=https://perbillion.com/api

# Spring
SPRING_PROFILES_ACTIVE=prod
