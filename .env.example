# PerBillion Environment Configuration
# Copy this file to .env and replace every change_me value before running.

# MongoDB
# Local Docker uses MONGO_PASSWORD to build the in-network MongoDB URI.
# For Atlas, set MONGODB_URI to your rotated SRV connection string, including the database.
# Example:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/perbillion?retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DATABASE=perbillion

# If you run the local MongoDB container and want to override its password:
MONGO_PASSWORD=change_me_local_mongo_password

# JWT Configuration
JWT_SECRET=change_me_256_bit_jwt_secret
JWT_EXPIRY=7d

# AWS Configuration (for production deployment)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
S3_BUCKET_NAME=perbillion-forecasts

# Alpha Vantage API (for stock data)
# Get your free API key at: https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=change_me_alpha_vantage_key

# Email Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password

# Application URLs
FRONTEND_URL=http://localhost
API_URL=http://localhost/api

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Environment
NODE_ENV=development
SPRING_PROFILES_ACTIVE=dev
